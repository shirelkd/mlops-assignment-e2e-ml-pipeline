NEBIUS_API_KEY=your_nebius_api_key_here

# Airflow UID (to avoid permission issues in docker volumes)
AIRFLOW_UID=50000

# Optional AWS S3 credentials for remote artifact storage (Phase 3 extension)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1
# S3_ARTIFACT_BUCKET=your_s3_bucket_name
